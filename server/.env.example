PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string

# Demo data seeding.
# - Unset / false (default): the full demo dataset is seeded ONCE, only when the
#   database is empty. Restarts never touch existing data.
# - true: the server WIPES every collection and reseeds from scratch on EVERY
#   connect/restart. Use only in development. NEVER set true in production —
#   it will erase a live database on each deploy.
RESEED_ON_START=false
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30
COOKIE_SAMESITE=lax

# Required only for first production setup when the database has no users.
# Send this value in the x-setup-secret header for the initial super_admin signup.
SETUP_SECRET=your_one_time_setup_secret

# REQUIRED in production — AES key used to encrypt Aadhaar PII at rest.
# The backend REFUSES TO START in production without it (no insecure fallback).
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Keep this value CONSTANT once set, or existing encrypted records won't decrypt.
ENCRYPTION_KEY=your_encryption_key

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma-separated origins that can call this API with cookies.
# Add your deployed frontend URL here after hosting it.
# If frontend and API share one Vercel project, add that same Vercel URL.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://your-client-domain.vercel.app

# Same value is also used by Socket.IO when running the local/long-running server.
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,https://your-client-domain.vercel.app

# Optional but recommended in production: shared Redis store for rate limits and Socket.IO scaling.
REDIS_URL=redis://localhost:6379

# Secret that guards the daily-report cron endpoint (GET /api/cron/daily-report).
# node-cron can't run on serverless, so a Vercel Cron calls that route with
# `Authorization: Bearer <CRON_SECRET>`. Set the same value in Vercel Cron settings.
CRON_SECRET=your_long_random_cron_secret

# Customer SMS / WhatsApp notifications (order ready, booking/reservation confirmed).
# Provider: 'log' (default — prints to server log, no config needed), 'msg91', or 'twilio'.
CUSTOMER_SMS_PROVIDER=log
CUSTOMER_SMS_COUNTRY_CODE=91
# MSG91 (India SMS)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CAFEOS
# Twilio (SMS, or WhatsApp when TWILIO_WHATSAPP=true)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_WHATSAPP=false
