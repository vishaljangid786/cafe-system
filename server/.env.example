PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=30d
JWT_COOKIE_EXPIRE=30

# REQUIRED in production — AES key used to encrypt Aadhaar PII at rest.
# The backend REFUSES TO START in production without it (no insecure fallback).
# Generate a strong value:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
# Keep this value CONSTANT once set, or existing encrypted records won't decrypt.
ENCRYPTION_KEY=your_encryption_key

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Comma-separated origins that can call this API with cookies.
# Add your deployed frontend URL here after hosting it.
# If frontend and API share one Vercel project, add that same Vercel URL.
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://your-client-domain.vercel.app

# Same value is also used by Socket.IO when running the local/long-running server.
CLIENT_URL=http://localhost:3000,http://127.0.0.1:3000,https://your-client-domain.vercel.app

# Secret that guards the daily-report cron endpoint (GET /api/cron/daily-report).
# node-cron can't run on serverless, so a Vercel Cron calls that route with
# `Authorization: Bearer <CRON_SECRET>`. Set the same value in Vercel Cron settings.
CRON_SECRET=your_long_random_cron_secret
