{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/daily-report",
      "schedule": "59 23 * * *"
    },
    {
      "path": "/api/cron/generate-payroll",
      "schedule": "30 0 1 * *"
    }
  ]
}
